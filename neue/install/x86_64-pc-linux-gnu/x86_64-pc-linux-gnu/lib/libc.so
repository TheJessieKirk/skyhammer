/* GNU ld script
   Use the shared library, but some functions are only in
   the static library, so try that secondarily.  */
OUTPUT_FORMAT(elf64-x86-64)
GROUP ( /usr/skyhammer/neue/install/x86_64-pc-linux-gnu/x86_64-pc-linux-gnu/lib/libc.so.6 /usr/skyhammer/neue/install/x86_64-pc-linux-gnu/x86_64-pc-linux-gnu/lib/libc_nonshared.a  AS_NEEDED ( /usr/skyhammer/neue/install/x86_64-pc-linux-gnu/x86_64-pc-linux-gnu/lib/ld-linux-x86-64.so.2 ) )
