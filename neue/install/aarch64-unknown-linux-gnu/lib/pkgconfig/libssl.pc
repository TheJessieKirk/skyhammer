prefix=/usr/skyhammer/neue/install/aarch64-unknown-linux-gnu
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: OpenSSL-libssl
Description: Secure Sockets Layer and cryptography libraries
Version: 3.2.0
Requires.private: libcrypto
Libs: -L${libdir} -lssl
Cflags: -I${includedir}
